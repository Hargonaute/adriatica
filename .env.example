# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker):  postgresql://postgres:postgres@localhost:5432/cmsdb
# Production:      your Vercel Postgres or external PostgreSQL URL
DATABASE_URL=

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ─── App (public) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Vercel Blob (for file uploads) ───────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob Store → .env.local tab
BLOB_READ_WRITE_TOKEN=

# ─── Legacy / Vercel Postgres (kept for backwards compat) ─────────────────────
# These are auto-injected by Vercel when you link a Postgres DB.
# For local dev, DATABASE_URL above is sufficient.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
